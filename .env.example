ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=sqlite+aiosqlite:///./wokly.db
# Set to 1 to skip AI calls and return a hardcoded fixture (useful for UI dev)
USE_MOCK_MENU=
# AI provider: anthropic (default) or openai
AI_PROVIDER=anthropic
# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
