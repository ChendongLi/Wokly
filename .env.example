ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=sqlite+aiosqlite:///./wokly.db
# Set to 1 to skip AI calls and return a hardcoded fixture (useful for UI dev)
USE_MOCK_MENU=
# AI provider: anthropic (default) or openai
AI_PROVIDER=anthropic
# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# --- Production (GCP Cloud Run) ---
# DATABASE_URL and API keys are injected via Secret Manager — do not set them here.
# CORS_ORIGINS is only needed if you call the API from a different origin (e.g. local dev
# against the production backend). Leave blank for the normal single-container Cloud Run deploy.
# CORS_ORIGINS=http://localhost:5173,https://menu.agentlens.net
